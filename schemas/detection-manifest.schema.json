{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/detection-as-code/detection-manifest.schema.json",
  "title": "Detection rule manifest",
  "type": "object",
  "required": ["rule_id", "title", "version", "status", "severity", "risk_score", "risk_rationale", "rule_path", "required_telemetry", "required_fields", "attack", "thresholds", "false_positive_hypotheses", "tests", "review", "playbook", "known_limitations"],
  "properties": {
    "rule_id": {"type": "string", "pattern": "^DET-[A-Z]+-[0-9]{3}$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"enum": ["idea", "development", "experimental", "validation", "production_candidate", "tuning_required", "deprecated"]},
    "severity": {"enum": ["low", "medium", "high", "critical"]},
    "risk_score": {"type": "integer", "minimum": 0, "maximum": 100}
  }
}
